<Window x:Class="STool.Modules.Clipboard.ClipboardPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="剪贴板历史"
        Width="720"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 顶部标签:悬浮胶囊;选中态 Tag="on" → 蓝色实心药丸 + 白字 -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="pill"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource SurfaceSunkenHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 列表行:白色行块浮于画布,间隙分隔,无线条;悬停浅蓝 -->
        <Style x:Key="ClipRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimarySubtleBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 来源应用徽章:中性色块药丸 -->
        <Style x:Key="SourceBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceSunkenBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0,44,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标签栏:悬浮胶囊组(灰底圆角容器,内含药丸标签) -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceSunkenBrush}"
                CornerRadius="18"
                Padding="4"
                HorizontalAlignment="Left"
                Margin="16,4,16,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="tabAll" Style="{StaticResource TabButton}" Tag="on" Content="全部" Click="Tab_Click"/>
                <Button x:Name="tabText" Style="{StaticResource TabButton}" Content="文本" Click="Tab_Click"/>
                <Button x:Name="tabImage" Style="{StaticResource TabButton}" Content="图像" Click="Tab_Click"/>
                <Button x:Name="tabFile" Style="{StaticResource TabButton}" Content="文件" Click="Tab_Click"/>
                <Button x:Name="tabFavorite" Style="{StaticResource TabButton}" Content="收藏" Click="Tab_Click"/>
            </StackPanel>
        </Border>

        <!-- 列表 + 悬浮清空按钮 -->
        <Grid Grid.Row="1">
            <!-- 空状态 -->
            <StackPanel x:Name="emptyState"
                        Style="{StaticResource EmptyStateContainer}"
                        Visibility="Collapsed">
                <TextBlock Text="&#xE8F4;" Style="{StaticResource EmptyStateIcon}"/>
                <TextBlock Text="暂无记录" Style="{StaticResource EmptyStateTitle}"/>
                <TextBlock Text="复制内容会自动保存到剪贴板历史中" Style="{StaticResource EmptyStateDescription}"/>
            </StackPanel>

            <!-- 滚动条 overlay(叠在内容上,不占布局宽)→ 左右 padding 数值相等、真正对称 -->
            <ScrollViewer x:Name="listScroll" VerticalScrollBarVisibility="Auto" Padding="16,4,16,4">
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Width="8"
                                       Margin="0,4,3,4"
                                       Background="Transparent"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                <ItemsControl x:Name="itemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ClipRow}"
                                    MouseLeftButtonDown="Item_MouseLeftButtonDown">
                                <Border.Tag>
                                    <Binding Path="Id"/>
                                </Border.Tag>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding FavoriteTooltip}" Click="MenuFavorite_Click"/>
                                        <MenuItem Header="删除" Click="MenuDelete_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 内容 + 时间 -->
                                    <StackPanel Margin="0,0,12,0">
                                        <Image Source="{Binding ImageSource}"
                                               MaxHeight="120"
                                               HorizontalAlignment="Left"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   LineHeight="20"
                                                   MaxHeight="62"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding RelativeTime}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"
                                                   ToolTip="{Binding FullTimestamp}"/>
                                    </StackPanel>

                                    <!-- 来源 + 尺寸 + 悬停操作 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Border Style="{StaticResource SourceBadge}"
                                                Visibility="{Binding HasSource, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding SourceApp}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding SizeText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 悬浮清空按钮 -->
            <Button x:Name="btnClearAll"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,20"
                    Width="46" Height="46"
                    Cursor="Hand"
                    ToolTip="清空剪贴板"
                    Click="BtnClearAll_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="fab"
                                Background="{StaticResource SurfaceBrush}"
                                BorderThickness="0"
                                CornerRadius="23">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" Opacity="0.14" ShadowDepth="0" Color="{StaticResource ShadowColor}"/>
                            </Border.Effect>
                            <TextBlock x:Name="ic" Text="&#xE74D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fab" Property="Background" Value="{StaticResource ErrorBrush}"/>
                                <Setter TargetName="fab" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                <Setter TargetName="ic" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
