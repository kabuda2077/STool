<Window x:Class="STool.Modules.Clipboard.ClipboardPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:STool.Core"
        Style="{StaticResource ModernWindow}"
        Title="剪贴板历史"
        Width="700"
        Height="540"
        MinWidth="540"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SettingsSection}"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch"
                         Style="{StaticResource ModernTextBox}"
                         Background="{StaticResource SurfaceBrush}"
                         BorderThickness="1"
                         Height="34"
                         VerticalAlignment="Center"
                         TextChanged="TxtSearch_TextChanged"
                         local:TextBoxWatermark.Watermark="搜索..."/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button x:Name="btnShowAll"
                            Style="{StaticResource SecondaryButton}"
                            Content="全部"
                            Padding="12,6"
                            Click="BtnShowAll_Click"/>

                    <Button x:Name="btnShowFavorites"
                            Style="{StaticResource SecondaryButton}"
                            Content="收藏"
                            Padding="12,6"
                            Margin="6,0,0,0"
                            Click="BtnShowFavorites_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource SettingsSection}"
                Padding="8">
            <Grid>
                <!-- 空状态 -->
                <StackPanel x:Name="emptyState"
                           Style="{StaticResource EmptyStateContainer}"
                           Visibility="Collapsed">
                    <TextBlock Text="&#xE8F4;"
                               Style="{StaticResource EmptyStateIcon}"/>
                    <TextBlock Text="暂无记录"
                               Style="{StaticResource EmptyStateTitle}"/>
                    <TextBlock Text="复制内容会自动保存到剪贴板历史中"
                               Style="{StaticResource EmptyStateDescription}"/>
                </StackPanel>

                <!-- 列表 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="itemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AnimatedListRow}"
                                        MouseLeftButtonDown="Item_MouseLeftButtonDown"
                                        Cursor="Hand">
                                    <Border.Tag>
                                        <Binding Path="Id"/>
                                    </Border.Tag>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="{Binding DisplayText}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13"
                                                       LineHeight="20"
                                                       MaxHeight="62"/>

                                            <TextBlock Text="{Binding RelativeTime}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,6,0,0"
                                                       ToolTip="{Binding FullTimestamp}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconButton}"
                                                    ToolTip="{Binding FavoriteTooltip}"
                                                    Click="BtnFavorite_Click">
                                                <Button.Tag>
                                                    <Binding Path="Id"/>
                                                </Button.Tag>
                                                <TextBlock Text="{Binding FavoriteGlyph}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14"/>
                                            </Button>

                                            <Button Style="{StaticResource DangerIconButton}"
                                                    ToolTip="删除"
                                                    Margin="4,0,0,0"
                                                    Click="BtnDelete_Click">
                                                <Button.Tag>
                                                    <Binding Path="Id"/>
                                                </Button.Tag>
                                                <TextBlock Text="&#xE74D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
