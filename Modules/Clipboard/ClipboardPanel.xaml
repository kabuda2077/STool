<Window x:Class="STool.Modules.Clipboard.ClipboardPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:STool.Core"
        Style="{StaticResource ModernWindow}"
        core:ModernWindowChrome.ShowTopmostButton="True"
        core:ModernWindowChrome.TitleBarExtraTopPadding="True"
        Title="剪贴板历史"
        Width="720"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{StaticResource TransparentBrush}"
                                Padding="10">
                            <Border Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="8"
                                    Padding="5">
                                <Border.Effect>
                                    <StaticResource ResourceKey="MenuShadow"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="root"
                                Background="{StaticResource TransparentBrush}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter TargetName="root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 顶部分类:白底分段切换;选中态蓝字加粗,与翻译引擎切换一致 -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 列表行:白色行块浮于画布,间隙分隔,无线条;悬停用稍深灰和背景区分 -->
        <Style x:Key="ClipRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 来源应用徽章:中性色块药丸 -->
        <Style x:Key="SourceBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="FavoriteButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImageInfoBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="0,6,6,0"/>
        </Style>

        <Style x:Key="ImageLargeBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="0,6,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0,58,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="4"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="tabAll" Style="{StaticResource TabButton}" Tag="on" Content="全部" Click="Tab_Click"/>
                    <Button x:Name="tabText" Style="{StaticResource TabButton}" Content="文本" Click="Tab_Click"/>
                    <Button x:Name="tabImage" Style="{StaticResource TabButton}" Content="图像" Click="Tab_Click"/>
                    <Button x:Name="tabFile" Style="{StaticResource TabButton}" Content="文件" Click="Tab_Click"/>
                    <Button x:Name="tabFavorite" Style="{StaticResource TabButton}" Content="收藏" Click="Tab_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Width="218"
                    Height="40"
                    Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0"
                    CornerRadius="8"
                    Padding="13,0"
                    HorizontalAlignment="Right">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="14"
                             Height="14"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconSearch}"
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="{StaticResource TransparentBrush}"/>
                        </Canvas>
                    </Viewbox>

                    <Grid Grid.Column="1" Height="32" VerticalAlignment="Center">
                        <TextBlock x:Name="searchPlaceholder"
                                   Text="搜索剪贴板"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   Opacity="0.72"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="txtSearch"
                                 Background="{StaticResource TransparentBrush}"
                                 BorderThickness="0"
                                 Padding="0"
                                 Height="32"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </Grid>

                    <Button x:Name="btnClearSearch"
                            Grid.Column="2"
                            Width="24"
                            Height="24"
                            Margin="8,0,0,0"
                            Padding="0"
                            Style="{StaticResource IconButton}"
                            ToolTip="清除搜索"
                            Visibility="Collapsed"
                            Click="BtnClearSearch_Click">
                        <Viewbox Width="12" Height="12">
                            <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconX}"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- 列表 + 悬浮清空按钮 -->
        <Grid Grid.Row="1">
            <!-- 空状态 -->
            <StackPanel x:Name="emptyState"
                        Style="{StaticResource EmptyStateContainer}"
                        Visibility="Collapsed">
                <Border Width="68"
                        Height="68"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="18"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <StaticResource ResourceKey="PaneShadow"/>
                    </Border.Effect>
                    <Grid>
                        <Viewbox x:Name="emptyClipboardIcon"
                                 Width="30"
                                 Height="30"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconClipboard}"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="{StaticResource TransparentBrush}"
                                      Opacity="0.72"/>
                            </Canvas>
                        </Viewbox>
                        <Viewbox x:Name="emptySearchIcon"
                                 Width="30"
                                 Height="30"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Visibility="Collapsed">
                            <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconSearch}"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="{StaticResource TransparentBrush}"
                                      Opacity="0.72"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Border>
                <TextBlock x:Name="emptyTitle" Text="暂无记录" Style="{StaticResource EmptyStateTitle}"/>
                <TextBlock x:Name="emptyDescription" Text="复制内容会自动保存到剪贴板历史中" Style="{StaticResource EmptyStateDescription}"/>
            </StackPanel>

            <!-- 列表:虚拟化 ListBox(Recycling + 像素滚动,行高不等);保留 8px 细滚动条 -->
            <ListBox x:Name="itemsList"
                     Background="{StaticResource TransparentBrush}"
                     BorderThickness="0"
                     Padding="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_Scroll"
                                          Focusable="False"
                                          Padding="10,0,10,4"
                                          CanContentScroll="True"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <Grid>
                                            <ScrollContentPresenter Margin="{TemplateBinding Padding}"
                                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                                       HorizontalAlignment="Right"
                                                       Width="8"
                                                       Margin="0,4,3,4"
                                                       Background="{StaticResource TransparentBrush}"
                                                       Value="{TemplateBinding VerticalOffset}"
                                                       Maximum="{TemplateBinding ScrollableHeight}"
                                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Grid>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ClipRow}"
                                MouseLeftButtonDown="Item_MouseLeftButtonDown">
                            <Border.Tag>
                                <Binding Path="Id"/>
                            </Border.Tag>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding FavoriteTooltip}" Click="MenuFavorite_Click"/>
                                    <MenuItem Header="另存为" Click="MenuSaveAs_Click" Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem Header="删除" Click="MenuDelete_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 内容 + 时间 -->
                                <StackPanel Margin="0,2,12,0"
                                            VerticalAlignment="Center">
                                    <Border Width="{Binding ThumbnailBoxWidth}"
                                            Height="{Binding ThumbnailBoxHeight}"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="6"
                                            ClipToBounds="True"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"
                                            MouseLeftButtonDown="ThumbPreview_MouseLeftButtonDown"
                                            ToolTip="预览图片">
                                        <Image Source="{Binding ImageSource}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Loaded="ThumbImage_Loaded"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayText}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               LineHeight="20"
                                               MaxHeight="62"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding RelativeTime}"
                                               FontSize="{StaticResource FontSizeMicro}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,8,0,0"
                                               ToolTip="{Binding FullTimestamp}"/>
                                </StackPanel>

                                <!-- 来源 + 收藏/尺寸 -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}">
                                        <Border Style="{StaticResource ImageLargeBadge}"
                                                Visibility="{Binding IsLargeImage, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="大图"
                                                       FontSize="{StaticResource FontSizeMicro}"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontWeight="{StaticResource FontWeightStrong}"/>
                                        </Border>
                                        <Border Style="{StaticResource ImageInfoBadge}"
                                                Margin="0,6,0,0">
                                            <TextBlock Text="{Binding ImageInfoText}"
                                                       FontSize="{StaticResource FontSizeMicro}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <Border Style="{StaticResource SourceBadge}"
                                            VerticalAlignment="Center"
                                            Margin="0,6,0,0"
                                            Visibility="{Binding HasSource, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding SourceApp}"
                                                   FontSize="{StaticResource FontSizeMicro}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                    <Button Style="{StaticResource FavoriteButton}"
                                            Tag="{Binding FavoriteState}"
                                            ToolTip="{Binding FavoriteTooltip}"
                                            Click="FavoriteButton_Click"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding FavoriteGlyph}"
                                                   FontSize="13"
                                                   LineHeight="13"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 悬浮清空按钮 -->
            <Button x:Name="btnClearAll"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,14,14"
                    Width="44" Height="44"
                    Cursor="Hand"
                    ToolTip="清空全部"
                    Click="BtnClearAll_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="fab"
                                Background="{StaticResource SurfaceBrush}"
                                BorderThickness="0"
                                CornerRadius="22">
                            <Border.Effect>
                                <StaticResource ResourceKey="MenuShadow"/>
                            </Border.Effect>
                            <Viewbox Width="20" Height="20"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="trashIcon"
                                          Data="{StaticResource IconTrash2}"
                                          Stroke="{StaticResource TextSecondaryBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="{StaticResource TransparentBrush}"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fab" Property="Background" Value="{StaticResource ErrorBrush}"/>
                                <Setter TargetName="fab" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                <Setter TargetName="trashIcon" Property="Stroke" Value="{StaticResource OnPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid x:Name="imagePreviewOverlay"
              Grid.RowSpan="2"
              Background="{StaticResource OverlayBrush}"
              Visibility="Collapsed"
              MouseLeftButtonDown="ImagePreviewOverlay_MouseLeftButtonDown">
            <Border Width="560"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                    MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MouseLeftButtonDown="ImagePreviewCard_MouseLeftButtonDown">
                <Border.Effect>
                    <StaticResource ResourceKey="MenuShadow"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,8">
                        <TextBlock x:Name="imagePreviewTitle"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="{StaticResource FontWeightStrong}"
                                   VerticalAlignment="Center"/>
                        <Button Width="28"
                                Height="28"
                                HorizontalAlignment="Right"
                                Style="{StaticResource IconButton}"
                                ToolTip="关闭预览"
                                Click="ClosePreview_Click">
                            <Viewbox Width="13" Height="13">
                                <Canvas Width="24" Height="24">
                                    <Path Data="{StaticResource IconX}"
                                          Stroke="{StaticResource TextSecondaryBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Image x:Name="imagePreview"
                               MaxHeight="420"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
