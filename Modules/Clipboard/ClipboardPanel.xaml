<Window x:Class="STool.Modules.Clipboard.ClipboardPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="剪贴板历史"
        Width="720"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{StaticResource TransparentBrush}"
                                Padding="10">
                            <Border Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="9"
                                    Padding="5">
                                <Border.Effect>
                                    <StaticResource ResourceKey="MenuShadow"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="root"
                                Background="{StaticResource TransparentBrush}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter TargetName="root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 顶部标签:悬浮胶囊;选中态 Tag="on" → 深色实心药丸 + 白字 -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="pill"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 列表行:白色行块浮于画布,间隙分隔,无线条;悬停用稍深灰和背景区分 -->
        <Style x:Key="ClipRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 来源应用徽章:中性色块药丸 -->
        <Style x:Key="SourceBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0,44,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,4,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 标签栏:悬浮胶囊组(灰底圆角容器,内含药丸标签) -->
            <Border Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="18"
                    Padding="4"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="tabAll" Style="{StaticResource TabButton}" Tag="on" Content="全部" Click="Tab_Click"/>
                    <Button x:Name="tabText" Style="{StaticResource TabButton}" Content="文本" Click="Tab_Click"/>
                    <Button x:Name="tabImage" Style="{StaticResource TabButton}" Content="图像" Click="Tab_Click"/>
                    <Button x:Name="tabFile" Style="{StaticResource TabButton}" Content="文件" Click="Tab_Click"/>
                    <Button x:Name="tabFavorite" Style="{StaticResource TabButton}" Content="收藏" Click="Tab_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Width="218"
                    Height="30"
                    Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0"
                    CornerRadius="15"
                    Padding="13,0"
                    HorizontalAlignment="Right">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <Grid Grid.Column="1" Height="30" VerticalAlignment="Center">
                        <TextBlock x:Name="searchPlaceholder"
                                   Text="搜索剪贴板"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   Opacity="0.72"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="txtSearch"
                                 Background="{StaticResource TransparentBrush}"
                                 BorderThickness="0"
                                 Padding="0"
                                 Height="30"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </Grid>

                    <Button x:Name="btnClearSearch"
                            Grid.Column="2"
                            Width="24"
                            Height="24"
                            Margin="8,0,0,0"
                            Padding="0"
                            Style="{StaticResource IconButton}"
                            ToolTip="清除搜索"
                            Visibility="Collapsed"
                            Click="BtnClearSearch_Click">
                        <Viewbox Width="12" Height="12">
                            <Canvas Width="24" Height="24">
                                <Path Data="M18 6 L6 18 M6 6 L18 18"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- 列表 + 悬浮清空按钮 -->
        <Grid Grid.Row="1">
            <!-- 空状态 -->
            <StackPanel x:Name="emptyState"
                        Style="{StaticResource EmptyStateContainer}"
                        Visibility="Collapsed">
                <TextBlock Text="&#xE8F4;" Style="{StaticResource EmptyStateIcon}"/>
                <TextBlock x:Name="emptyTitle" Text="暂无记录" Style="{StaticResource EmptyStateTitle}"/>
                <TextBlock x:Name="emptyDescription" Text="复制内容会自动保存到剪贴板历史中" Style="{StaticResource EmptyStateDescription}"/>
            </StackPanel>

            <!-- 滚动条 overlay(叠在内容上,不占布局宽)→ 左右 padding 数值相等、真正对称 -->
            <ScrollViewer x:Name="listScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,4,16,4">
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Width="8"
                                       Margin="0,4,3,4"
                                       Background="{StaticResource TransparentBrush}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                <ItemsControl x:Name="itemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ClipRow}"
                                    MouseLeftButtonDown="Item_MouseLeftButtonDown">
                                <Border.Tag>
                                    <Binding Path="Id"/>
                                </Border.Tag>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding FavoriteTooltip}" Click="MenuFavorite_Click"/>
                                        <MenuItem Header="删除" Click="MenuDelete_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 内容 + 时间 -->
                                    <StackPanel Margin="0,0,12,0">
                                        <Image Source="{Binding ImageSource}"
                                               MaxHeight="120"
                                               HorizontalAlignment="Left"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   LineHeight="20"
                                                   MaxHeight="62"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding RelativeTime}"
                                                   FontSize="{StaticResource FontSizeMicro}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"
                                                   ToolTip="{Binding FullTimestamp}"/>
                                    </StackPanel>

                                    <!-- 来源 + 尺寸 + 悬停操作 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Border Style="{StaticResource SourceBadge}"
                                                Visibility="{Binding HasSource, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding SourceApp}"
                                                       FontSize="{StaticResource FontSizeMicro}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding SizeText}"
                                                   FontSize="{StaticResource FontSizeMicro}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 悬浮清空按钮 -->
            <Button x:Name="btnClearAll"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,20"
                    Width="46" Height="46"
                    Cursor="Hand"
                    ToolTip="清空全部"
                    Click="BtnClearAll_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="fab"
                                Background="{StaticResource SurfaceBrush}"
                                BorderThickness="0"
                                CornerRadius="23">
                            <Border.Effect>
                                <StaticResource ResourceKey="MenuShadow"/>
                            </Border.Effect>
                            <Viewbox Width="18" Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="trashLid"
                                          Data="M4 7 H20 M9 7 V5 A1 1 0 0 1 10 4 H14 A1 1 0 0 1 15 5 V7"
                                          Stroke="{StaticResource TextSecondaryBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                    <Path x:Name="trashBody"
                                          Data="M6 7 L7 20 A2 2 0 0 0 9 22 H15 A2 2 0 0 0 17 20 L18 7 M10 11 V18 M14 11 V18"
                                          Stroke="{StaticResource TextSecondaryBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="{StaticResource TransparentBrush}"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fab" Property="Background" Value="{StaticResource ErrorBrush}"/>
                                <Setter TargetName="fab" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                <Setter TargetName="trashLid" Property="Stroke" Value="{StaticResource OnPrimaryBrush}"/>
                                <Setter TargetName="trashBody" Property="Stroke" Value="{StaticResource OnPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
