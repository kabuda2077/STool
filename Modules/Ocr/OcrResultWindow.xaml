<Window x:Class="STool.Modules.Ocr.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="OCR 识别结果"
        Width="600"
        Height="440"
        MinWidth="460"
        MinHeight="340"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="OcrResultPane" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Effect" Value="{StaticResource StandardShadow}"/>
        </Style>

        <Style x:Key="OcrResultTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Background="{TemplateBinding Background}"
                                      Focusable="False"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16,52,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource OcrResultPane}">
            <TextBox x:Name="txtResult"
                     Style="{StaticResource OcrResultTextBox}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     IsReadOnly="False"
                     VerticalScrollBarVisibility="Auto"/>
        </Border>

        <Grid Grid.Row="1" Margin="8,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="txtProvider"
                       Text="提供商: Windows Local"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>

            <Button x:Name="btnClose"
                    Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnClose_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="关闭"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCopy"
                    Grid.Column="2"
                    Style="{StaticResource ModernButton}"
                    Click="BtnCopy_Click"
                    Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8C8;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="复制"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
