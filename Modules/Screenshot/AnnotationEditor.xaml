<Window x:Class="STool.Modules.Screenshot.AnnotationEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Grid>
        <Image x:Name="screenshotImage" Stretch="None"/>
        <Canvas x:Name="annotationCanvas" Background="Transparent"/>

        <Border x:Name="toolbarBorder"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="9"
                Padding="7"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  Opacity="0.16"
                                  ShadowDepth="0"
                                  Color="{StaticResource ShadowColor}"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" Height="36">
                <Button x:Name="btnRectangle"
                        Style="{StaticResource IconButton}"
                        Click="BtnRectangle_Click"
                        ToolTip="矩形">
                    <TextBlock Text="□" FontSize="15"/>
                </Button>

                <Button x:Name="btnEllipse"
                        Style="{StaticResource IconButton}"
                        Click="BtnEllipse_Click"
                        Margin="3,0,0,0"
                        ToolTip="椭圆">
                    <TextBlock Text="○" FontSize="15"/>
                </Button>

                <Button x:Name="btnArrow"
                        Style="{StaticResource IconButton}"
                        Click="BtnArrow_Click"
                        Margin="3,0,0,0"
                        ToolTip="箭头">
                    <TextBlock Text="→" FontSize="16"/>
                </Button>

                <Button x:Name="btnPen"
                        Style="{StaticResource IconButton}"
                        Click="BtnPen_Click"
                        Margin="3,0,0,0"
                        ToolTip="画笔">
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>

                <Rectangle Width="1" Height="22" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                <Button x:Name="btnUndo"
                        Style="{StaticResource IconButton}"
                        Click="BtnUndo_Click"
                        ToolTip="撤销">
                    <TextBlock Text="↶" FontSize="17"/>
                </Button>

                <Button x:Name="btnRedo"
                        Style="{StaticResource IconButton}"
                        Click="BtnRedo_Click"
                        Margin="3,0,0,0"
                        ToolTip="重做">
                    <TextBlock Text="↷" FontSize="17"/>
                </Button>

                <Rectangle Width="1" Height="22" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                <Button x:Name="btnDone"
                        Style="{StaticResource ModernButton}"
                        Click="BtnDone_Click"
                        Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="完成"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnCancel"
                        Style="{StaticResource IconButton}"
                        Click="BtnCancel_Click"
                        Margin="6,0,0,0"
                        ToolTip="取消">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
