<Window x:Class="STool.Modules.Screenshot.AnnotationEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        ShowInTaskbar="False">
    <Grid>
        <Image x:Name="screenshotImage" Stretch="None"/>
        <Canvas x:Name="annotationCanvas" Background="{StaticResource TransparentBrush}"/>

        <Border x:Name="toolbarBorder"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8"
                Padding="6"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,20">
            <Border.Effect>
                <StaticResource ResourceKey="MenuShadow"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" Height="36">
                <Button x:Name="btnRectangle"
                        Style="{StaticResource IconButton}"
                        Click="BtnRectangle_Click"
                        ToolTip="矩形">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconRectangle}"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  Fill="{StaticResource TransparentBrush}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="btnEllipse"
                        Style="{StaticResource IconButton}"
                        Click="BtnEllipse_Click"
                        Margin="3,0,0,0"
                        ToolTip="椭圆">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconCircle}"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  Fill="{StaticResource TransparentBrush}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="btnArrow"
                        Style="{StaticResource IconButton}"
                        Click="BtnArrow_Click"
                        Margin="3,0,0,0"
                        ToolTip="箭头">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconArrowUpRight}"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="btnPen"
                        Style="{StaticResource IconButton}"
                        Click="BtnPen_Click"
                        Margin="3,0,0,0"
                        ToolTip="画笔">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconPenLine}"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="{StaticResource TransparentBrush}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Rectangle Width="0.5" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                <Button x:Name="btnUndo"
                        Style="{StaticResource IconButton}"
                        Click="BtnUndo_Click"
                        ToolTip="撤销">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconUndo2}"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="btnRedo"
                        Style="{StaticResource IconButton}"
                        Click="BtnRedo_Click"
                        Margin="3,0,0,0"
                        ToolTip="重做">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconRedo2}"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Rectangle Width="0.5" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                <Button x:Name="btnDone"
                        Style="{StaticResource ModernButton}"
                        Click="BtnDone_Click"
                        Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="{StaticResource IconCheck}"
                                      Stroke="{StaticResource OnPrimaryBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="完成"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnCancel"
                        Style="{StaticResource IconButton}"
                        Click="BtnCancel_Click"
                        Margin="6,0,0,0"
                        ToolTip="取消">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconX}"
                                  Stroke="{StaticResource ErrorBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
