<Window x:Class="STool.Modules.Screenshot.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1A1A1A"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Cursor="Cross"
        KeyDown="Window_KeyDown">

    <Grid x:Name="rootGrid" ClipToBounds="True">
        <!-- 冻结的屏幕画面 -->
        <Image x:Name="screenshotImage" Stretch="Fill"/>

        <!-- 选区操作层:空白拖=新建选区,框内拖=移动;标注/手柄叠在其上 -->
        <Canvas x:Name="overlayCanvas" Background="Transparent">
            <!-- 蒙版:框外淡黑,框内挖洞(EvenOdd) -->
            <Path x:Name="maskPath" Fill="#66000000" IsHitTestVisible="False"/>

            <!-- 标注层:覆盖选区,工具激活时才可命中绘制 -->
            <Canvas x:Name="annotationCanvas" IsHitTestVisible="False" ClipToBounds="True"/>

            <!-- 选区边框 -->
            <Border x:Name="selectionBorder"
                    BorderBrush="#2DC472"
                    BorderThickness="2"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- 尺寸标签 -->
            <Border x:Name="sizeLabel"
                    Background="#D21A1A1A"
                    CornerRadius="4"
                    Padding="8,3"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="sizeText" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <!-- 工具条(位置在代码中按选区计算并夹紧屏幕) -->
            <Border x:Name="toolbar"
                    Background="{StaticResource ToolbarBrush}"
                    CornerRadius="9"
                    Padding="6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.30" ShadowDepth="0" Color="{StaticResource ShadowColor}"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" Height="34">
                    <Button x:Name="btnRect" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Rectangle" ToolTip="矩形">
                        <Rectangle Width="16" Height="13" RadiusX="2.5" RadiusY="2.5"
                                   Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.7" Fill="Transparent"/>
                    </Button>
                    <Button x:Name="btnEllipse" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Ellipse" Margin="2,0,0,0" ToolTip="椭圆">
                        <Ellipse Width="16" Height="14"
                                 Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.7" Fill="Transparent"/>
                    </Button>
                    <Button x:Name="btnArrow" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Arrow" Margin="2,0,0,0" ToolTip="箭头">
                        <Path Data="M4,18 L17,5 M17,5 L10.5,5 M17,5 L17,11.5"
                              Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.7"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                    </Button>
                    <Button x:Name="btnPen" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Pen" Margin="2,0,0,0" ToolTip="画笔">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                    <Button x:Name="btnUndo" Style="{StaticResource IconButton}" Click="BtnUndo_Click" ToolTip="撤销 (Ctrl+Z)">
                        <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="btnRedo" Style="{StaticResource IconButton}" Click="BtnRedo_Click" Margin="2,0,0,0" ToolTip="重做 (Ctrl+Y)">
                        <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                    <Button x:Name="btnSave" Style="{StaticResource IconButton}" Click="BtnSave_Click" ToolTip="保存 (Ctrl+S)">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="btnPin" Style="{StaticResource IconButton}" Click="BtnPin_Click" Margin="2,0,0,0" ToolTip="钉到屏幕">
                        <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="btnOcr" Style="{StaticResource IconButton}" Click="BtnOcr_Click" Margin="2,0,0,0" ToolTip="OCR 识别">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="btnTranslate" Style="{StaticResource IconButton}" Click="BtnTranslate_Click" Margin="2,0,0,0" ToolTip="翻译">
                        <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                    <Button x:Name="btnCancel" Style="{StaticResource DangerIconButton}" Click="BtnCancel_Click" ToolTip="取消 (Esc)">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="15"/>
                    </Button>
                    <Button x:Name="btnConfirm" Style="{StaticResource IconButton}" Foreground="{StaticResource SuccessBrush}" Click="BtnConfirm_Click" Margin="2,0,0,0" ToolTip="完成,复制到剪贴板 (Enter)">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
