<Window x:Class="STool.Modules.Screenshot.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource ScreenshotOverlayBackgroundBrush}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Cursor="Cross"
        KeyDown="Window_KeyDown">

    <Grid x:Name="rootGrid" ClipToBounds="True">
        <!-- 冻结的屏幕画面 -->
        <Image x:Name="screenshotImage" Stretch="Fill"/>

        <!-- 选区操作层:空白拖=新建选区,框内拖=移动;标注/手柄叠在其上 -->
        <Canvas x:Name="overlayCanvas" Background="{StaticResource TransparentBrush}">
            <!-- 蒙版:框外淡黑,框内挖洞(EvenOdd) -->
            <Path x:Name="maskPath" Fill="{StaticResource ScreenshotMaskBrush}" IsHitTestVisible="False"/>

            <!-- 标注层:覆盖选区,工具激活时才可命中绘制(需 Background 才能接收鼠标) -->
            <Canvas x:Name="annotationCanvas" Background="{StaticResource TransparentBrush}" IsHitTestVisible="False" ClipToBounds="True"/>

            <!-- 分块原位翻译层:优先按 OCR 坐标局部替换文字,失败时回退到下方整块翻译层 -->
            <Canvas x:Name="translationBlockCanvas"
                    Visibility="Collapsed"
                    ClipToBounds="True"
                    IsHitTestVisible="False"/>

            <!-- 原位翻译层:覆盖选区内容,模拟微信截图的"原文替换为译文"效果 -->
            <Border x:Name="translationOverlay"
                    Background="{StaticResource SurfaceBrush}"
                    Padding="8"
                    Visibility="Collapsed"
                    ClipToBounds="True"
                    IsHitTestVisible="False">
                <ScrollViewer x:Name="translationOverlayScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="translationOverlayText"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               LineHeight="20"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </ScrollViewer>
            </Border>

            <!-- 选区边框 -->
            <Border x:Name="selectionBorder"
                    BorderBrush="{StaticResource SuccessBrush}"
                    BorderThickness="2"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- 尺寸标签 -->
            <Border x:Name="sizeLabel"
                    Background="{StaticResource ScreenshotSizeLabelBrush}"
                    CornerRadius="4"
                    Padding="8,3"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="sizeText" Foreground="{StaticResource OnPrimaryBrush}" FontSize="{StaticResource FontSizeCaption}" FontWeight="{StaticResource FontWeightStrong}"/>
            </Border>

            <!-- 工具条(位置在代码中按选区计算并夹紧屏幕) -->
            <Border x:Name="toolbar"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Border.Effect>
                    <StaticResource ResourceKey="StandardShadow"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnRect" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Rectangle" ToolTip="矩形">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconRectangle}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnEllipse" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Ellipse" Margin="2,0,0,0" ToolTip="椭圆">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconCircle}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnArrow" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Arrow" Margin="2,0,0,0" ToolTip="箭头">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconArrowUpRight}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnPen" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Pen" Margin="2,0,0,0" ToolTip="画笔">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconPenLine}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnMosaic" Style="{StaticResource IconButton}" Click="Tool_Click" Tag="Mosaic" Margin="2,0,0,0" ToolTip="马赛克">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconMosaic}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  Fill="{StaticResource TransparentBrush}"/>
                        </Canvas></Viewbox>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                    <Button x:Name="btnUndo" Style="{StaticResource IconButton}" Click="BtnUndo_Click" ToolTip="撤销 (Ctrl+Z)">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconUndo2}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnRedo" Style="{StaticResource IconButton}" Click="BtnRedo_Click" Margin="2,0,0,0" ToolTip="重做 (Ctrl+Y)">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconRedo2}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                    <Button x:Name="btnSave" Style="{StaticResource IconButton}" Click="BtnSave_Click" ToolTip="保存 (Ctrl+S)">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconDownload}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnPin" Style="{StaticResource IconButton}" Click="BtnPin_Click" Margin="2,0,0,0" ToolTip="钉到屏幕">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconPin}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="-45"/>
                                </Path.RenderTransform>
                            </Path>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnOcr" Style="{StaticResource IconButton}" Click="BtnOcr_Click" Margin="2,0,0,0" ToolTip="OCR 识别">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconScanText}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnTranslate" Style="{StaticResource IconButton}" Click="BtnTranslate_Click" Margin="2,0,0,0" ToolTip="翻译">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconLanguages}"
                                  Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="7,0"/>

                    <Button x:Name="btnCancel" Style="{StaticResource DangerIconButton}" Click="BtnCancel_Click" ToolTip="取消 (Esc)">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconX}"
                                  Stroke="{StaticResource ErrorBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="btnConfirm" Style="{StaticResource IconButton}" Click="BtnConfirm_Click" Margin="2,0,0,0" ToolTip="完成 (Enter)">
                        <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconCheck}"
                                  Stroke="{StaticResource SuccessBrush}" StrokeThickness="2.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas></Viewbox>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
