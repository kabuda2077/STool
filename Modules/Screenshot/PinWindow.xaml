<Window x:Class="STool.Modules.Screenshot.PinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        KeyDown="Window_KeyDown">

    <Border x:Name="mainBorder"
            BorderThickness="0"
            CornerRadius="6"
            Background="{StaticResource SurfaceBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Opacity="0.16"
                              ShadowDepth="0"
                              Color="{StaticResource ShadowColor}"/>
        </Border.Effect>

        <Grid>
            <Image x:Name="screenshotImage"
                   Stretch="Uniform"
                   MouseLeftButtonDown="Image_MouseLeftButtonDown"
                   MouseWheel="Image_MouseWheel"/>

            <Border x:Name="toolbar"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,4,4,0"
                    Visibility="Collapsed">
                <Button x:Name="btnClose"
                        Width="24"
                        Height="24"
                        Cursor="Hand"
                        Background="#B30F172A"
                        Foreground="White"
                        ToolTip="关闭 (Esc / 双击)"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="12">
                                <TextBlock Text="&#xE8BB;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#DC2626"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
