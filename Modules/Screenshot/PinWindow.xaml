<Window x:Class="STool.Modules.Screenshot.PinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        KeyDown="Window_KeyDown">

    <Border x:Name="mainBorder"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Background="{StaticResource SurfaceBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Opacity="0.25"
                              ShadowDepth="0"
                              Color="{StaticResource ShadowColor}"/>
        </Border.Effect>

        <Grid>
            <Image x:Name="screenshotImage"
                   Stretch="None"
                   MouseLeftButtonDown="Image_MouseLeftButtonDown"
                   MouseWheel="Image_MouseWheel"/>

            <Border x:Name="toolbar"
                    Background="#E60F172A"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Padding="6"
                    CornerRadius="0,6,0,6"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnClose"
                            Width="28"
                            Height="28"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="关闭 (Esc / 双击)"
                            Click="BtnClose_Click">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
