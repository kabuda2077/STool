<Window x:Class="STool.Modules.Screenshot.PinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Border x:Name="mainBorder"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Background="{StaticResource SurfaceBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Opacity="0.25"
                              ShadowDepth="0"
                              Color="{StaticResource ShadowColor}"/>
        </Border.Effect>

        <Grid>
            <Image x:Name="screenshotImage"
                   Stretch="None"
                   MouseWheel="Image_MouseWheel"/>

            <Border x:Name="toolbar"
                    Background="#E60F172A"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Padding="6"
                    CornerRadius="0,6,0,6"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="2,0,6,0">
                        <TextBlock Text="透明度"
                                   FontSize="12"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                        <Slider x:Name="opacitySlider"
                                Width="86"
                                Minimum="0.3"
                                Maximum="1.0"
                                Value="1.0"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                ValueChanged="OpacitySlider_ValueChanged"/>
                    </StackPanel>

                    <Button x:Name="btnClose"
                            Width="28"
                            Height="28"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnClose_Click">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
