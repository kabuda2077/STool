<Window x:Class="STool.Modules.Screenshot.PinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        KeyDown="Window_KeyDown">

    <Border x:Name="mainBorder"
            BorderThickness="0"
            CornerRadius="6"
            Background="{StaticResource SurfaceBrush}"
            Margin="14">
        <Border.Effect>
            <StaticResource ResourceKey="MenuShadow"/>
        </Border.Effect>

        <Grid>
            <Image x:Name="screenshotImage"
                   Stretch="Uniform"
                   MouseLeftButtonDown="Image_MouseLeftButtonDown"
                   MouseWheel="Image_MouseWheel"/>

            <Border x:Name="toolbar"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,4,4,0"
                    Visibility="Collapsed">
                <Button x:Name="btnClose"
                        Width="34"
                        Height="34"
                        Cursor="Hand"
                        Background="{StaticResource PinnedCloseBackgroundBrush}"
                        Foreground="{StaticResource OnPrimaryBrush}"
                        ToolTip="关闭 (Esc / 双击)"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="17">
                                <TextBlock Text="&#xE8BB;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource ErrorBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
