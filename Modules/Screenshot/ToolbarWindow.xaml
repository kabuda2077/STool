<Window x:Class="STool.Modules.Screenshot.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Border Background="{StaticResource ToolbarBrush}"
            CornerRadius="9"
            Padding="7"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              Opacity="0.28"
                              ShadowDepth="0"
                              Color="{StaticResource ShadowColor}"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" Height="36">
            <Button x:Name="btnSave"
                    Style="{StaticResource IconButton}"
                    Click="BtnSave_Click"
                    ToolTip="保存 (Ctrl+S)">
                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <Button x:Name="btnCopy"
                    Style="{StaticResource IconButton}"
                    Click="BtnCopy_Click"
                    Margin="3,0,0,0"
                    ToolTip="复制 (Ctrl+C)">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <Rectangle Width="1" Height="22" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

            <Button x:Name="btnAnnotate"
                    Style="{StaticResource IconButton}"
                    Click="BtnAnnotate_Click"
                    ToolTip="标注 (A)">
                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <Button x:Name="btnOcr"
                    Style="{StaticResource IconButton}"
                    Margin="3,0,0,0"
                    Click="BtnOcr_Click"
                    ToolTip="OCR 识别 (O)">
                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <Button x:Name="btnTranslate"
                    Style="{StaticResource IconButton}"
                    Margin="3,0,0,0"
                    Click="BtnTranslate_Click"
                    ToolTip="原位翻译 (T)">
                <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <Button x:Name="btnPin"
                    Style="{StaticResource IconButton}"
                    Margin="3,0,0,0"
                    Click="BtnPin_Click"
                    ToolTip="钉图 (P)">
                <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <Rectangle Width="1" Height="22" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

            <Button x:Name="btnClose"
                    Style="{StaticResource IconButton}"
                    Click="BtnClose_Click"
                    ToolTip="关闭 (Esc)">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
            </Button>
        </StackPanel>
    </Border>
</Window>
