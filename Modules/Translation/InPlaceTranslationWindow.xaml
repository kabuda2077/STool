<Window x:Class="STool.Modules.Translation.InPlaceTranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource TransparentBrush}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MinWidth="260"
        MinHeight="110"
        KeyDown="Window_KeyDown">

    <Border x:Name="mainBorder"
            Background="{StaticResource SurfaceBrush}"
            CornerRadius="8"
            Padding="14">
        <Border.Effect>
            <StaticResource ResourceKey="StandardShadow"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,2,0">
                <TextBlock x:Name="txtTranslated"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource FontSizeBody}"
                           LineHeight="21"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </ScrollViewer>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtProvider"
                           FontSize="{StaticResource FontSizeMicro}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <Button x:Name="btnCopy"
                        Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        ToolTip="复制译文"
                        Click="BtnCopy_Click">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconCopy}"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="{StaticResource TransparentBrush}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button x:Name="btnClose"
                        Grid.Column="2"
                        Style="{StaticResource DangerIconButton}"
                        ToolTip="关闭 (Esc)"
                        Click="BtnClose_Click"
                        Margin="4,0,0,0">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="24" Height="24">
                            <Path Data="{StaticResource IconX}"
                                  Stroke="{StaticResource ErrorBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
