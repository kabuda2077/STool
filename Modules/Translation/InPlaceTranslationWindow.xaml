<Window x:Class="STool.Modules.Translation.InPlaceTranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="原位翻译"
        Width="560"
        Height="430"
        MinWidth="460"
        MinHeight="360"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SettingsSection}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="识别文本" Style="{StaticResource SettingsGroupTitle}"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,2,0,0">
                    <TextBlock x:Name="txtOriginal"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeBody}"
                               LineHeight="21"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SettingsSection}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="翻译结果" Style="{StaticResource SettingsGroupTitle}"/>
                    <TextBlock x:Name="txtProvider"
                               Grid.Column="1"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,2,0,0">
                    <TextBlock x:Name="txtTranslated"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               LineHeight="22"
                               FontWeight="{StaticResource FontWeightStrong}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="btnClose"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnClose_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="关闭"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCopy"
                    Style="{StaticResource ModernButton}"
                    Click="BtnCopy_Click"
                    Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8C8;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="复制译文"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
