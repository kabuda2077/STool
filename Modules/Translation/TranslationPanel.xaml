<Window x:Class="STool.Modules.Translation.TranslationPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="翻译"
        Width="720"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="TranslationPane" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Effect" Value="{StaticResource PaneShadow}"/>
        </Style>

        <Style x:Key="TranslationTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Background="{TemplateBinding Background}"
                                      Focusable="False"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SourceClearButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 提供商切换按钮:选中态用 Tag="on" 触发 -->
        <Style x:Key="ProviderToggle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="TranslationLanguageComboToggleTemplate" TargetType="ToggleButton">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderThickness="0"
                    CornerRadius="7">
                <Grid>
                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                          Fill="{StaticResource TextSecondaryBrush}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="TranslationLanguageComboBoxItem" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="{StaticResource FontWeightNormal}"/>
        </Style>

        <Style x:Key="TranslationLanguageComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="7,6"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource TranslationLanguageComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource TranslationLanguageComboToggleTemplate}"
                                          Background="{TemplateBinding Background}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>

                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   HorizontalOffset="-8"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        Padding="3,2"
                                        Margin="8,6,8,10">
                                    <Border.Effect>
                                        <StaticResource ResourceKey="MenuShadow"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="240"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 浮动操作按钮:无边框,悬停/按下色块反馈 -->
        <Style x:Key="FloatingAction" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16,52,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.08*" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- 上半部:输入 + 工具栏 -->
        <Border Grid.Row="0"
                Style="{StaticResource TranslationPane}">
            <Grid>
                <TextBox x:Name="txtSource"
                         Style="{StaticResource TranslationTextBox}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="TxtSource_TextChanged"/>
                <TextBlock x:Name="srcWatermark"
                           Text="请输入要翻译的内容，可右键点击文本框粘贴"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top"
                           Margin="0,0,0,0"/>
                <Button x:Name="btnClearSource"
                        Style="{StaticResource SourceClearButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        ToolTip="清空"
                        Click="BtnClearSource_Click">
                    <TextBlock Text="&#xE894;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- 工具栏 -->
        <Grid Grid.Row="1" Margin="0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 提供商切换 -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="4">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnProviderGoogle" Style="{StaticResource ProviderToggle}" Click="Provider_Click" Tag="on" Content="谷歌翻译"/>
                    <Button x:Name="btnProviderTencent" Style="{StaticResource ProviderToggle}" Click="Provider_Click" Content="腾讯翻译"/>
                </StackPanel>
            </Border>

            <!-- 语言选择:源 → 目标 -->
            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="3">
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="cmbSource" Style="{StaticResource TranslationLanguageComboBox}" Width="90" Height="32" SelectedIndex="0">
                        <ComboBoxItem Content="自动检测" Tag="auto"/>
                        <ComboBoxItem Content="中文" Tag="zh"/>
                        <ComboBoxItem Content="英文" Tag="en"/>
                        <ComboBoxItem Content="日文" Tag="ja"/>
                        <ComboBoxItem Content="韩文" Tag="ko"/>
                    </ComboBox>
                    <TextBlock Text="&#xE72A;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="5,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="cmbTarget" Style="{StaticResource TranslationLanguageComboBox}" Width="78" Height="32" SelectedIndex="1">
                        <ComboBoxItem Content="中文" Tag="zh"/>
                        <ComboBoxItem Content="英文" Tag="en"/>
                        <ComboBoxItem Content="日文" Tag="ja"/>
                        <ComboBoxItem Content="韩文" Tag="ko"/>
                    </ComboBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 下半部:翻译结果(单边框) -->
        <Border Grid.Row="2"
                Style="{StaticResource TranslationPane}">
            <Grid>
                <TextBox x:Name="txtTarget"
                         Style="{StaticResource TranslationTextBox}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="TxtTarget_TextChanged"/>
                <TextBlock x:Name="tgtWatermark"
                           Text="翻译结果"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top"
                           Margin="0"/>

                <!-- 浮动操作条:贴结果区底部;两层结构(空白层投阴影 + 内容层无特效)防 HiDPI 文字锯齿 -->
                <Grid x:Name="actionBar"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      Margin="0,0,0,0">
                    <!-- 阴影层:无文字,仅投柔和阴影 -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8">
                        <Border.Effect>
                            <StaticResource ResourceKey="MenuShadow"/>
                        </Border.Effect>
                    </Border>
                    <!-- 内容层:无特效,文字原生渲染 -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnCopyOnly" Style="{StaticResource FloatingAction}" Click="BtnCopyOnly_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="仅复制"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnCopyHide" Style="{StaticResource FloatingAction}" Click="BtnCopyHide_Click" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="复制并隐藏"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnCopyInput" Style="{StaticResource FloatingAction}" Click="BtnCopyInput_Click" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="复制并输入"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
