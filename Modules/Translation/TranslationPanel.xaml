<Window x:Class="STool.Modules.Translation.TranslationPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="翻译"
        Width="700"
        Height="520"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SettingsSection}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="原文" Style="{StaticResource SettingsGroupTitle}"/>

                <TextBox x:Name="txtSource"
                         Grid.Row="1"
                         Style="{StaticResource ModernTextBox}"
                         BorderThickness="0"
                         Background="Transparent"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="TxtSource_TextChanged"
                         Margin="0,2,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource SettingsSection}"
                Padding="10"
                Margin="0,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="cmbSourceLanguage"
                      Width="128"
                      Height="34"
                      SelectedIndex="0"
                      Style="{StaticResource ModernComboBox}">
                <ComboBoxItem Content="自动检测" Tag="auto"/>
                <ComboBoxItem Content="中文" Tag="zh"/>
                <ComboBoxItem Content="英文" Tag="en"/>
                <ComboBoxItem Content="日文" Tag="ja"/>
                <ComboBoxItem Content="韩文" Tag="ko"/>
            </ComboBox>

            <Button x:Name="btnSwapLanguages"
                    Grid.Column="1"
                    Style="{StaticResource IconButton}"
                    Width="32"
                    Height="32"
                    Margin="12,0"
                    ToolTip="交换语言"
                    Click="BtnSwapLanguages_Click">
                <TextBlock Text="&#xE8AB;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Button>

            <ComboBox x:Name="cmbTargetLanguage"
                      Grid.Column="2"
                      Width="128"
                      Height="34"
                      SelectedIndex="1"
                      Style="{StaticResource ModernComboBox}">
                <ComboBoxItem Content="中文" Tag="zh"/>
                <ComboBoxItem Content="英文" Tag="en"/>
                <ComboBoxItem Content="日文" Tag="ja"/>
                <ComboBoxItem Content="韩文" Tag="ko"/>
            </ComboBox>

            <Button x:Name="btnTranslate"
                    Grid.Column="4"
                    Style="{StaticResource ModernButton}"
                    Click="BtnTranslate_Click"
                    Padding="18,7"
                    IsEnabled="False">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="loadingSpinner"
                                Style="{StaticResource LoadingSpinner}"
                                Width="14"
                                Height="14"
                                Margin="0,0,7,0"
                                Visibility="Collapsed"/>
                        <TextBlock x:Name="translateIcon"
                                   Text="&#xE8AC;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="翻译"/>
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SettingsSection}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="译文" Style="{StaticResource SettingsGroupTitle}"/>
                    <TextBlock x:Name="txtProvider"
                               Grid.Column="1"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <TextBox x:Name="txtTarget"
                         Grid.Row="1"
                         Style="{StaticResource ModernTextBox}"
                         BorderThickness="0"
                         Background="Transparent"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="False"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,2,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="btnClear"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnClear_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE894;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="清空"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCopy"
                    Style="{StaticResource ModernButton}"
                    Click="BtnCopy_Click"
                    IsEnabled="False"
                    Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8C8;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="复制译文"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
