<Window x:Class="STool.Modules.Translation.TranslationPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="翻译"
        Width="720"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 提供商切换按钮:选中态用 Tag="on" 触发 -->
        <Style x:Key="ProviderToggle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{StaticResource SurfaceSunkenBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceSunkenHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PrimarySubtleBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 浮动操作按钮:无边框,悬停/按下色块反馈 -->
        <Style x:Key="FloatingAction" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceSunkenHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceSunkenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14,44,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- 上半部:输入 + 工具栏 -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 输入框(单边框,聚焦变蓝) -->
            <Grid Grid.Row="0">
                <TextBox x:Name="txtSource"
                         Style="{StaticResource SunkenTextBox}"
                         FontSize="{StaticResource FontSizeBody}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         TextChanged="TxtSource_TextChanged"/>
                <TextBlock x:Name="srcWatermark"
                           Text="请输入要翻译的内容，可右键点击文本框粘贴"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top"
                           Margin="7,6,0,0"/>
            </Grid>

            <!-- 工具栏 -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 提供商切换 -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnProviderGoogle" Style="{StaticResource ProviderToggle}" Click="Provider_Click" Tag="on" Content="谷歌翻译"/>
                    <Button x:Name="btnProviderTencent" Style="{StaticResource ProviderToggle}" Click="Provider_Click" Margin="8,0,0,0" Content="腾讯翻译"/>
                </StackPanel>

                <!-- 语言选择:源 → 目标 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox x:Name="cmbSource" Style="{StaticResource SunkenComboBox}" Width="106" Height="32" SelectedIndex="0">
                        <ComboBoxItem Content="自动检测" Tag="auto"/>
                        <ComboBoxItem Content="中文" Tag="zh"/>
                        <ComboBoxItem Content="英文" Tag="en"/>
                        <ComboBoxItem Content="日文" Tag="ja"/>
                        <ComboBoxItem Content="韩文" Tag="ko"/>
                    </ComboBox>
                    <TextBlock Text="&#xE72A;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="cmbTarget" Style="{StaticResource SunkenComboBox}" Width="106" Height="32" SelectedIndex="1">
                        <ComboBoxItem Content="中文" Tag="zh"/>
                        <ComboBoxItem Content="英文" Tag="en"/>
                        <ComboBoxItem Content="日文" Tag="ja"/>
                        <ComboBoxItem Content="韩文" Tag="ko"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 分隔条 -->
        <GridSplitter Grid.Row="1"
                      Height="10"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"/>

        <!-- 下半部:翻译结果(单边框) -->
        <Grid Grid.Row="2">
            <TextBox x:Name="txtTarget"
                     Style="{StaticResource SunkenTextBox}"
                     FontSize="{StaticResource FontSizeBody}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"
                     TextChanged="TxtTarget_TextChanged"/>
            <TextBlock x:Name="tgtWatermark"
                       Text="翻译结果"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       IsHitTestVisible="False"
                       VerticalAlignment="Top"
                       Margin="7,6,0,0"/>

            <!-- 浮动操作条:贴结果区右下角;两层结构(空白层投阴影 + 内容层无特效)防 HiDPI 文字锯齿 -->
            <Grid x:Name="actionBar"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Bottom"
                  Margin="0,0,0,14">
                <!-- 阴影层:无文字,仅投柔和阴影 -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10">
                    <Border.Effect>
                        <StaticResource ResourceKey="StandardShadow"/>
                    </Border.Effect>
                </Border>
                <!-- 内容层:无特效,文字原生渲染 -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="10"
                        Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnCopyOnly" Style="{StaticResource FloatingAction}" Click="BtnCopyOnly_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="仅复制"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnCopyHide" Style="{StaticResource FloatingAction}" Click="BtnCopyHide_Click" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="复制并隐藏"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnCopyInput" Style="{StaticResource FloatingAction}" Click="BtnCopyInput_Click" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="复制并输入"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
