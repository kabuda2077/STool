<Window x:Class="STool.Modules.Translation.TranslationPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="翻译"
        Width="720"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 提供商切换按钮:选中态用 Tag="on" 触发 -->
        <Style x:Key="ProviderToggle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource PrimarySubtleBrush}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- 上半部:输入 + 工具栏 -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 输入框 -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <TextBox x:Name="txtSource"
                             Style="{StaticResource ModernTextBox}"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             FontSize="14"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             TextChanged="TxtSource_TextChanged"/>
                    <TextBlock x:Name="srcWatermark"
                               Text="请输入要翻译的内容，可右键点击文本框粘贴"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               IsHitTestVisible="False"
                               VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- 工具栏 -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 提供商切换 -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnProviderGoogle" Style="{StaticResource ProviderToggle}" Click="Provider_Click" Tag="on" Content="谷歌翻译"/>
                    <Button x:Name="btnProviderTencent" Style="{StaticResource ProviderToggle}" Click="Provider_Click" Margin="8,0,0,0" Content="腾讯翻译"/>
                </StackPanel>

                <!-- 翻译按钮(灯泡) -->
                <Button x:Name="btnTranslate"
                        Grid.Column="2"
                        Style="{StaticResource ModernButton}"
                        Click="BtnTranslate_Click"
                        Width="42"
                        Padding="0"
                        Margin="0,0,10,0"
                        ToolTip="翻译 (Ctrl+Enter)"
                        IsEnabled="False">
                    <Grid>
                        <Border x:Name="loadingSpinner"
                                Style="{StaticResource LoadingSpinner}"
                                Width="15" Height="15"
                                Visibility="Collapsed"/>
                        <Path x:Name="translateIcon"
                              Data="M9 15 A5 5 0 1 1 15 15 L15 16.5 L9 16.5 Z M9.5 19 L14.5 19 M10.5 22 L13.5 22"
                              Stroke="White" StrokeThickness="1.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Width="18" Height="18" Stretch="Uniform"/>
                    </Grid>
                </Button>

                <!-- 语言选择:源 → 目标 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <ComboBox x:Name="cmbSource" Width="106" Height="32" SelectedIndex="0">
                        <ComboBoxItem Content="自动检测" Tag="auto"/>
                        <ComboBoxItem Content="中文" Tag="zh"/>
                        <ComboBoxItem Content="英文" Tag="en"/>
                        <ComboBoxItem Content="日文" Tag="ja"/>
                        <ComboBoxItem Content="韩文" Tag="ko"/>
                    </ComboBox>
                    <TextBlock Text="&#xE72A;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="cmbTarget" Width="106" Height="32" SelectedIndex="1">
                        <ComboBoxItem Content="中文" Tag="zh"/>
                        <ComboBoxItem Content="英文" Tag="en"/>
                        <ComboBoxItem Content="日文" Tag="ja"/>
                        <ComboBoxItem Content="韩文" Tag="ko"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 分隔条 -->
        <GridSplitter Grid.Row="1"
                      Height="10"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"/>

        <!-- 下半部:翻译结果 -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <TextBox x:Name="txtTarget"
                         Style="{StaticResource ModernTextBox}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         FontSize="14"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         TextChanged="TxtTarget_TextChanged"/>
                <TextBlock x:Name="tgtWatermark"
                           Text="翻译结果"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top"/>
                <Button x:Name="btnCopy"
                        Style="{StaticResource IconButton}"
                        Click="BtnCopy_Click"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,-4,-4,0"
                        Visibility="Collapsed"
                        ToolTip="复制译文">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
