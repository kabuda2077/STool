<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neutral palette with blue accent matching the app icon -->
    <Color x:Key="PrimaryColor">#1D4ED8</Color>
    <Color x:Key="PrimarySoftColor">#E8F0FF</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F4F4F5</Color>
    <Color x:Key="BorderColor">#E4E4E7</Color>
    <Color x:Key="TextPrimaryColor">#18181B</Color>
    <Color x:Key="TextSecondaryColor">#71717A</Color>
    <Color x:Key="SuccessColor">#2DC472</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource PrimarySoftColor}"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

    <!-- Overlay for modals/screenshots -->
    <SolidColorBrush x:Key="OverlayBrush" Color="#99000000"/>
    <SolidColorBrush x:Key="ScreenshotOverlayBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ScreenshotMaskBrush" Color="#66000000"/>
    <SolidColorBrush x:Key="ScreenshotSizeLabelBrush" Color="#D21A1A1A"/>
    <SolidColorBrush x:Key="PinnedCloseBackgroundBrush" Color="#8C3F3F46"/>
    <Color x:Key="AnnotationDefaultColor">#DC2626</Color>

    <!-- Standard shadow for all elevated surfaces -->
    <Color x:Key="ShadowColor">#0B1220</Color>
    <DropShadowEffect x:Key="StandardShadow" Color="{StaticResource ShadowColor}" BlurRadius="12" ShadowDepth="1" Direction="270" Opacity="0.04" RenderingBias="Quality"/>
    <DropShadowEffect x:Key="PaneShadow" Color="{StaticResource ShadowColor}" BlurRadius="10" ShadowDepth="1" Direction="270" Opacity="0.02" RenderingBias="Quality"/>
    <DropShadowEffect x:Key="MenuShadow" Color="{StaticResource ShadowColor}" BlurRadius="16" ShadowDepth="2" Direction="270" Opacity="0.10" RenderingBias="Quality"/>

</ResourceDictionary>
