<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:core="clr-namespace:STool.Core"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <!-- 原生 Win11 窗口外框:SingleBorderWindow + WindowChrome 自定义标题栏,
         圆角与投影由 DWM 提供(见 Core/ModernWindowChrome.cs),不再用 AllowsTransparency 自绘。 -->
    <Style x:Key="ModernWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Icon" Value="/Resources/STool.ico"/>
        <Setter Property="WindowStyle" Value="SingleBorderWindow"/>
        <Setter Property="ResizeMode" Value="CanResize"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="core:ModernWindowChrome.Enabled" Value="True"/>
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome CaptionHeight="43"
                                    ResizeBorderThickness="6"
                                    CornerRadius="0"
                                    GlassFrameThickness="0"
                                    UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border x:Name="PART_WindowRoot"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="PART_TitleBar"
                                    Grid.Row="0"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="{TemplateBinding Title}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="18,0,120,0"/>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,7,8,7"
                                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                            <Button x:Name="PART_MinimizeButton"
                                                    Style="{StaticResource WindowCaptionButton}"
                                                    ToolTip="最小化">
                                                <TextBlock Text="&#xE921;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"/>
                                            </Button>
                                            <Button x:Name="PART_MaximizeButton"
                                                    Style="{StaticResource WindowCaptionButton}"
                                                    Margin="2,0,0,0"
                                                    ToolTip="最大化">
                                                <TextBlock x:Name="PART_MaximizeGlyph"
                                                           Text="&#xE922;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"/>
                                            </Button>
                                            <Button x:Name="PART_CloseButton"
                                                    Style="{StaticResource WindowCloseButton}"
                                                    Margin="2,0,0,0"
                                                    ToolTip="关闭">
                                                <TextBlock Text="&#xE8BB;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="{StaticResource BackgroundBrush}">
                                    <AdornerDecorator>
                                        <ContentPresenter/>
                                    </AdornerDecorator>
                                </Border>
                            </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 最大化时去掉 1px 外边框(WindowChrome 会自动将最大化尺寸约束到工作区) -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="PART_WindowRoot" Property="BorderThickness" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="PanelStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>

    <Style x:Key="SettingsSection" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- 色块分层:无边框白底卡片,靠柔和阴影从画布浮起(替代边框分组) -->
    <Style x:Key="SurfaceCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
        <Setter Property="Effect" Value="{StaticResource Elevation1}"/>
    </Style>

    <Style x:Key="SettingsPageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="19"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SettingsGroupTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- 可折叠分组:标题行点击展开/收起,右侧 chevron 旋转 -->
    <Style x:Key="SettingsExpander" TargetType="Expander">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Content="{TemplateBinding Header}"
                                      Cursor="Hand"
                                      Focusable="False"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      FocusVisualStyle="{x:Null}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="HeaderBg" Background="Transparent" CornerRadius="6" Padding="2,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter TextElement.FontSize="14"
                                                              TextElement.FontWeight="SemiBold"
                                                              TextElement.Foreground="{StaticResource TextPrimaryBrush}"
                                                              VerticalAlignment="Center"/>
                                            <Path x:Name="Chevron"
                                                  Grid.Column="1"
                                                  Data="M5 8 L10 13 L15 8"
                                                  Stroke="{StaticResource TextSecondaryBrush}"
                                                  StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Width="15" Height="15"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0"/>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HeaderBg" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chevron" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="180"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Margin="0,8,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ListRowStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

</ResourceDictionary>
