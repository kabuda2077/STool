<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:core="clr-namespace:STool.Core"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <!-- 原生 Win11 窗口外框:SingleBorderWindow + WindowChrome 自定义标题栏,
         圆角与投影由 DWM 提供(见 Core/ModernWindowChrome.cs),不再用 AllowsTransparency 自绘。 -->
    <Style x:Key="ModernWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="WindowStyle" Value="SingleBorderWindow"/>
        <Setter Property="ResizeMode" Value="CanResize"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="Auto"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="core:ModernWindowChrome.Enabled" Value="True"/>
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome CaptionHeight="48"
                                    ResizeBorderThickness="6"
                                    CornerRadius="0"
                                    GlassFrameThickness="0"
                                    UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border x:Name="PART_WindowRoot"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <!-- 内容铺满整窗:标题栏为顶部透明浮层,各页面自行预留顶部约 44px。
                                 这样带侧边栏的页面,侧边栏色块可贯通全高,形成左右两栏结构。 -->
                            <Border Background="{StaticResource SurfaceAltBrush}">
                                <AdornerDecorator>
                                    <ContentPresenter/>
                                </AdornerDecorator>
                            </Border>

                            <!-- 顶部浮层:标题(左)+ 窗口按钮(右);拖拽由 WindowChrome.CaptionHeight 处理 -->
                            <Grid x:Name="PART_TitleBar"
                                  VerticalAlignment="Top"
                                  Height="50">
                                <TextBlock Text="{TemplateBinding Title}"
                                           x:Name="PART_TitleText"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           FontWeight="{StaticResource FontWeightStrong}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="18,2,140,0"/>

                                <StackPanel Orientation="Horizontal"
                                            x:Name="PART_CaptionButtons"
                                            HorizontalAlignment="Right"
                                            Margin="0,11,10,7"
                                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Button x:Name="PART_TopmostButton"
                                            Style="{StaticResource WindowCaptionButton}"
                                            ToolTip="置顶窗口"
                                            Visibility="Collapsed">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path x:Name="PART_TopmostIcon"
                                                      Data="{StaticResource IconPin}"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="{StaticResource TransparentBrush}"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="-45"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <Button x:Name="PART_MinimizeButton"
                                            Style="{StaticResource WindowCaptionButton}"
                                            Margin="2,0,0,0"
                                            ToolTip="最小化">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="{StaticResource IconMinimize}"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <Button x:Name="PART_MaximizeButton"
                                            Style="{StaticResource WindowCaptionButton}"
                                            Margin="2,0,0,0"
                                            ToolTip="最大化">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path x:Name="PART_MaximizeIcon"
                                                      Data="{StaticResource IconMaximize}"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <Button x:Name="PART_CloseButton"
                                            Style="{StaticResource WindowCloseButton}"
                                            Margin="2,0,0,0"
                                            ToolTip="关闭">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="{StaticResource IconX}"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="core:ModernWindowChrome.ShowTopmostButton" Value="True">
                            <Setter TargetName="PART_TopmostButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="core:ModernWindowChrome.HideTitleText" Value="True">
                            <Setter TargetName="PART_TitleText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="core:ModernWindowChrome.TitleBarExtraTopPadding" Value="True">
                            <Setter TargetName="PART_TitleBar" Property="Height" Value="62"/>
                            <Setter TargetName="PART_TitleText" Property="Margin" Value="18,2,140,0"/>
                            <Setter TargetName="PART_CaptionButtons" Property="Margin" Value="0,11,10,13"/>
                        </Trigger>
                        <!-- 最大化时去掉 1px 外边框(WindowChrome 会自动将最大化尺寸约束到工作区) -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="PART_WindowRoot" Property="BorderThickness" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Settings section container (bordered, used by InPlaceTranslationWindow) -->
    <Style x:Key="SettingsSection" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- 色块分层:无边框白底卡片,靠柔和阴影从画布浮起(替代边框分组) -->
    <Style x:Key="SurfaceCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Effect" Value="{StaticResource PaneShadow}"/>
    </Style>

    <Style x:Key="SettingsPageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SettingsGroupTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- 表单字段标签:Caption 字号,次要色,用于输入框/下拉框前的字段名 -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,7,0,4"/>
    </Style>

    <!-- 可折叠分组:标题行点击展开/收起,右侧 chevron 旋转 -->
    <Style x:Key="SettingsExpander" TargetType="Expander">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Content="{TemplateBinding Header}"
                                      Cursor="Hand"
                                      Focusable="False"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      FocusVisualStyle="{x:Null}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Margin="-10">
                                        <Border x:Name="HeaderBg" Background="{StaticResource TransparentBrush}" CornerRadius="8" Padding="10,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter TextElement.FontSize="{StaticResource FontSizeBody}"
                                                              TextElement.FontWeight="{StaticResource FontWeightStrong}"
                                                              TextElement.Foreground="{StaticResource TextPrimaryBrush}"
                                                              VerticalAlignment="Center"/>
                                            <Path x:Name="Chevron"
                                                  Grid.Column="1"
                                                  Data="M5 8 L10 13 L15 8"
                                                  Stroke="{StaticResource TextSecondaryBrush}"
                                                  StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Width="15" Height="15"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0"/>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Grid>
                                    </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HeaderBg" Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chevron" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="180"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <!-- 折叠态用 ScaleY=0 收起布局高度; Margin 放在内部 ContentPresenter 上,
                             让外层 Border 的 LayoutTransform 连同 Margin 一起缩放为零 -->
                        <Border x:Name="ExpandSite">
                            <Border.LayoutTransform>
                                <ScaleTransform ScaleY="0"/>
                            </Border.LayoutTransform>
                            <ContentPresenter Margin="0,8,0,0"/>
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ExpandSite"
                                                         Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ExpandSite"
                                                         Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)"
                                                         To="0"
                                                         Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMicro}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ListRowStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

</ResourceDictionary>
