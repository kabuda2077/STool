<Window x:Class="STool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="设置"
        Width="760"
        Height="620"
        MinWidth="640"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="14,46,14,16">
            <StackPanel>
                <Button x:Name="btnGeneralSettings"
                        Click="BtnGeneralSettings_Click"
                        Style="{StaticResource NavigationButton}"
                        Content="通用"/>

                <Button x:Name="btnOcrSettings"
                        Click="BtnOcrSettings_Click"
                        Style="{StaticResource NavigationButton}"
                        Margin="0,4,0,0"
                        Content="OCR"/>

                <Button x:Name="btnTranslationSettings"
                        Click="BtnTranslationSettings_Click"
                        Style="{StaticResource NavigationButton}"
                        Margin="0,4,0,0"
                        Content="翻译"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{StaticResource SurfaceCanvasBrush}">
            <ScrollViewer x:Name="contentScroll"
                          Margin="0,44,0,0"
                          VerticalScrollBarVisibility="Auto"
                          Background="Transparent"
                          FocusVisualStyle="{x:Null}"
                          PreviewMouseWheel="ContentScroll_PreviewMouseWheel"
                          Padding="0">
                <Grid x:Name="contentPanel" Margin="22,10,22,22"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
