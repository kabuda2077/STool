<Window x:Class="STool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="设置"
        Width="760"
        Height="620"
        MinWidth="640"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="168"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="12,16">
            <StackPanel>
                <Button x:Name="btnGeneralSettings"
                        Click="BtnGeneralSettings_Click"
                        Style="{StaticResource NavigationButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Width="22"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="通用" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnOcrSettings"
                        Click="BtnOcrSettings_Click"
                        Style="{StaticResource NavigationButton}"
                        Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Width="22"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="OCR" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnTranslationSettings"
                        Click="BtnTranslationSettings_Click"
                        Style="{StaticResource NavigationButton}"
                        Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8AC;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Width="22"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="翻译" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnClipboardSettings"
                        Click="BtnClipboardSettings_Click"
                        Style="{StaticResource NavigationButton}"
                        Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Width="22"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="剪贴板" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{StaticResource BackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Background="Transparent"
                          Padding="0">
                <Grid x:Name="contentPanel" Margin="22,18"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
